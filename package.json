{
  "name": "blog-hichee-com",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "cf:wrangler": "npm_config_ignore_scripts=true npx --yes wrangler",
    "new:post": "node scripts/new-post.mjs",
    "migrate:download:wxr": "node scripts/download-wp-export.mjs",
    "migrate:download:rest": "node scripts/export-wp-rest.mjs",
    "migrate:convert:wxr": "node scripts/convert-wxr-to-content.mjs && node scripts/convert-posts-to-mdx.mjs",
    "migrate:convert:rest": "node scripts/convert-rest-to-content.mjs && node scripts/convert-posts-to-mdx.mjs",
    "migrate:posts:mdx": "node scripts/convert-posts-to-mdx.mjs",
    "migrate:related:legacy": "node scripts/extract-legacy-related-posts.mjs",
    "migrate:media:manifest": "node scripts/build-media-manifest.mjs",
    "migrate:drafts:issues": "node scripts/create-draft-issues.mjs",
    "audit:parity": "node scripts/audit-parity.mjs",
    "audit:visual": "node scripts/audit-visual-parity.mjs"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.13",
    "@astrojs/sitemap": "^3.6.0",
    "astro": "^5.14.3",
    "fast-xml-parser": "^5.3.1",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "playwright": "^1.58.2"
  }
}
