---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  bodyClass?: string;
  suppressFooter?: boolean;
}

const {
  title,
  description = 'The HiChee Blog and Travel Guide',
  canonical,
  bodyClass = '',
  suppressFooter = false
} = Astro.props;

const site = Astro.site?.toString() ?? 'https://newblog.hichee.com';
const canonicalUrl = canonical ? new URL(canonical, site).toString() : undefined;
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Blog For Travelers' },
  { href: '/hichee-blog-for-hosts/', label: 'Blog For Hosts' },
  { href: 'https://hichee.com/', label: 'Main Site' }
];

const isActive = (href: string) => {
  if (href.startsWith('http')) return false;
  if (href === '/') return currentPath === '/' || currentPath === '/the-hichee-blog/';
  return currentPath.startsWith(href);
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl ?? Astro.url.toString()} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <slot name="head" />
    <title>{title}</title>
  </head>
  <body class={bodyClass}>
    <header class="site-header">
      <div class="container nav-wrap">
        <a href="/" class="brand">
          <img
            src="https://blog.hichee.com/wp-content/uploads/2022/07/hichee-logo-64-pix-1.jpg"
            alt="HiChee"
            width="123"
            height="64"
            loading="eager"
          />
          <span class="brand__name">The HiChee Blog and Travel Guide</span>
        </a>
        <nav class="top-nav" aria-label="Primary">
          {
            navLinks.map((link) => (
              <a
                class:list={[
                  'top-nav__link',
                  isActive(link.href) && 'is-active',
                  link.href.startsWith('http') && 'is-external'
                ]}
                href={link.href}
                target={link.href.startsWith('http') ? '_blank' : undefined}
                rel={link.href.startsWith('http') ? 'noreferrer' : undefined}
              >
                {link.label}
              </a>
            ))
          }
        </nav>
      </div>
    </header>
    <main id="main" class="container page-shell">
      <slot />
    </main>
    {!suppressFooter && (
      <footer class="site-footer">
        <div class="container footer-wrap">
          <div>
            <strong>HiChee</strong>
            <p>
              <a href="https://hichee.com/about" target="_blank" rel="noreferrer">About</a>
              {' · '}
              <a href="https://hichee.com/privacy-policy" target="_blank" rel="noreferrer">Privacy Policy</a>
              {' · '}
              <a href="https://hichee.com/terms-of-service" target="_blank" rel="noreferrer">Terms Of Service</a>
            </p>
          </div>
          <p>© {new Date().getFullYear()} HiChee.com. All rights reserved.</p>
        </div>
      </footer>
    )}
  </body>
</html>
