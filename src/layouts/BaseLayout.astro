---
import '../styles/global.css';
import { normalizeWpUploadUrl } from '../lib/media';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  bodyClass?: string;
  suppressFooter?: boolean;
}

const {
  title,
  description = 'The HiChee Blog and Travel Guide',
  canonical,
  bodyClass = '',
  suppressFooter = false
} = Astro.props;

const site = Astro.site?.toString() ?? 'https://newblog.hichee.com';
const canonicalUrl = canonical ? new URL(canonical, site).toString() : undefined;
const currentPath = Astro.url.pathname;
const faviconHref = '/favicon.png';
const faviconIcoHref = '/favicon.ico';
const brandImageSrc = normalizeWpUploadUrl('https://blog.hichee.com/wp-content/uploads/2022/07/hichee-logo-64-pix-1.jpg');

const navLinks = [
  { href: '/', label: 'Blog For Travelers' },
  { href: '/hichee-blog-for-hosts/', label: 'Blog For Hosts' },
  { href: 'https://hichee.com/', label: 'Main Site' }
];

const footerSections = [
  {
    title: 'HiChee',
    links: [
      { href: 'https://hichee.com/about', label: 'About' },
      { href: '/', label: 'Blog' },
      { href: 'https://www.shakacode.com/career/', label: 'Career' },
      { href: 'https://hichee.com/privacy-policy', label: 'Privacy Policy' },
      { href: 'https://hichee.com/terms-of-service', label: 'Terms Of Service' }
    ]
  },
  {
    title: 'Hosting',
    links: [
      { href: 'https://hichee.com/hosts', label: 'Boost Direct Bookings' },
      { href: 'https://hichee.com/listing-verification', label: 'Verify Your Listing' },
      { href: '/hichee-blog-for-hosts/', label: 'Blog For Hosts' },
      { label: 'HiChee Support' }
    ]
  },
  {
    title: 'For Travelers',
    links: [{ href: 'https://hichee.com/contact-host', label: 'Contact Host' }]
  }
];

const isActive = (href: string) => {
  if (href.startsWith('http')) return false;
  if (href === '/') return currentPath === '/' || currentPath === '/the-hichee-blog/';
  return currentPath.startsWith(href);
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl ?? Astro.url.toString()} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" href={faviconIcoHref} sizes="any" />
    <link rel="icon" href={faviconHref} sizes="32x32" type="image/png" />
    <link rel="icon" href={faviconHref} sizes="192x192" type="image/png" />
    <link rel="apple-touch-icon" href={faviconHref} />
    <meta name="msapplication-TileImage" content={faviconHref} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <slot name="head" />
    <title>{title}</title>
  </head>
  <body class={bodyClass}>
    <header class="site-header">
      <div class="container nav-wrap">
        <a href="/" class="brand">
          <img
            src={brandImageSrc}
            alt="HiChee"
            width="123"
            height="64"
            loading="eager"
          />
          <span class="brand__name">The HiChee Blog and Travel Guide</span>
        </a>
        <nav class="top-nav top-nav--desktop" aria-label="Primary">
          {
            navLinks.map((link) => (
              <a
                class:list={['top-nav__link', isActive(link.href) && 'is-active']}
                href={link.href}
                target={link.href.startsWith('http') ? '_blank' : undefined}
                rel={link.href.startsWith('http') ? 'noreferrer' : undefined}
              >
                {link.label}
              </a>
            ))
          }
        </nav>
        <details class="top-nav-disclosure">
          <summary class="top-nav-toggle" aria-label="Toggle navigation">
            <span></span>
            <span></span>
            <span></span>
          </summary>
          <nav class="top-nav top-nav--mobile" aria-label="Primary">
            {
              navLinks.map((link) => (
                <a
                  class:list={['top-nav__link', isActive(link.href) && 'is-active']}
                  href={link.href}
                  target={link.href.startsWith('http') ? '_blank' : undefined}
                  rel={link.href.startsWith('http') ? 'noreferrer' : undefined}
                >
                  {link.label}
                </a>
              ))
            }
          </nav>
        </details>
      </div>
    </header>
    <main id="main" class="container page-shell">
      <slot />
    </main>
    {!suppressFooter && (
      <footer class="site-footer">
        <div class="container site-footer__inner">
          <div class="site-footer__grid">
            {
              footerSections.map((section) => (
                <section class="site-footer__section">
                  <h2>{section.title}</h2>
                  <div class="site-footer__links">
                    {
                      section.links.map((link) =>
                        link.href ? (
                          <a
                            href={link.href}
                            target={link.href.startsWith('http') ? '_blank' : undefined}
                            rel={link.href.startsWith('http') ? 'noreferrer' : undefined}
                          >
                            {link.label}
                          </a>
                        ) : (
                          <span>{link.label}</span>
                        )
                      )
                    }
                  </div>
                </section>
              ))
            }
          </div>
          <p class="site-footer__copyright">© 2024 HiChee.com. All rights reserved.</p>
        </div>
      </footer>
    )}
  </body>
</html>
