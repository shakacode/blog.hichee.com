---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { rewriteWpUploadsInHtml } from '../lib/media';

const pages = (await getCollection('pages')).filter((entry) => !entry.data.draft && entry.data.status === 'publish');
const homePage = pages.find((entry) => entry.data.wordpressId === 156 || entry.data.path === '/the-hichee-blog/');
const site = Astro.site?.toString() ?? 'https://newblog.hichee.com';

const legacyHomeHtml = homePage ? rewriteHomeHtml(homePage.body) : '';
const homeShareHtml = homePage ? buildHomeShareHtml(homePage.data.title) : '';

function rewriteHomeHtml(body: string): string {
  const hrefPattern = /href=(["'])https?:\/\/blog\.hichee\.com([^"']*)\1/gi;
  const rewrittenLinks = body.replace(hrefPattern, (full, quote, pathValue) => {
    const rewritten = rewriteInternalHref(pathValue);
    if (rewritten === null) return full;
    return `href=${quote}${rewritten}${quote}`;
  });

  // Preserve homepage visual parity by avoiding deferred image paint in static blocks.
  return rewriteWpUploadsInHtml(rewrittenLinks).replace(/\sloading=(["'])lazy\1/gi, '');
}

function rewriteInternalHref(pathValue: string): string | null {
  const raw = String(pathValue || '');
  if (!raw || raw === '/') return '/';
  if (raw.startsWith('/wp-content/') || raw.startsWith('/wp-admin/') || raw.startsWith('/wp-json/')) return null;
  if (raw.startsWith('/#') || raw.startsWith('/?') || /[?&]amp=1/i.test(raw)) return '#';

  const withoutQuery = raw.split('#')[0].split('?')[0].replace(/%ef%bf%bc/gi, '');
  if (!withoutQuery || withoutQuery === '/') return '/';

  const withLeadingSlash = withoutQuery.startsWith('/') ? withoutQuery : `/${withoutQuery}`;
  return withLeadingSlash.endsWith('/') ? withLeadingSlash : `${withLeadingSlash}/`;
}

function buildHomeShareHtml(title: string): string {
  const shareUrl = new URL('/', site).toString();
  const linkUrl = encodeURIComponent(shareUrl);
  const linkName = encodeURIComponent(title);
  const escapedTitle = title.replace(/&/g, '&amp;').replace(/"/g, '&quot;');
  const channels = [
    { channel: 'facebook', label: 'Facebook', glyph: 'f' },
    { channel: 'twitter', label: 'Twitter', glyph: 't' },
    { channel: 'pinterest', label: 'Pinterest', glyph: 'p' },
    { channel: 'whatsapp', label: 'WhatsApp', glyph: 'w' },
    { channel: 'email', label: 'Email', glyph: '@' },
    { channel: 'share', label: 'Share', glyph: '+' }
  ];

  const socialLinks = channels
    .map(
      (item) => {
        const href = item.channel === 'share'
          ? `https://www.addtoany.com/share#url=${linkUrl}&title=${linkName}`
          : `https://www.addtoany.com/add_to/${item.channel}?linkurl=${linkUrl}&linkname=${linkName}`;
        return `<a class="a2a_button_${item.channel} legacy-share-link legacy-share-link--${item.channel}" href="${href}" title="${item.label}" aria-label="${item.label}" rel="nofollow noopener" target="_blank"><span class="legacy-share-link__glyph" aria-hidden="true">${item.glyph}</span></a>`;
      }
    )
    .join('');

  return `<div class="addtoany_share_save_container addtoany_content addtoany_content_bottom"><div class="a2a_kit a2a_kit_size_32 addtoany_list legacy-share-list" data-a2a-url="${shareUrl}" data-a2a-title="${escapedTitle}">${socialLinks}</div></div>`;
}
---

<BaseLayout
  title="The HiChee Blog and Travel Guide"
  description="Insider travel tips and destination guides from HiChee."
  canonical="/"
  bodyClass="legacy-home home wp-theme-kadence wp-custom-logo"
>
  <Fragment slot="head">
    <link rel="stylesheet" href="/wp-legacy/wp-block-library.min.css" />
    <link rel="stylesheet" href="/wp-legacy/wp-block-theme.min.css" />
    <link rel="stylesheet" href="/wp-legacy/getwid-blocks.style.css" />
    <link rel="stylesheet" href="/wp-legacy/kadence-global.min.css" />
    <link rel="stylesheet" href="/wp-legacy/kadence-header.min.css" />
    <link rel="stylesheet" href="/wp-legacy/kadence-footer.min.css" />
    <link rel="stylesheet" href="/wp-legacy/ultimate-post-style.min.css" />
    <link rel="stylesheet" href="/wp-legacy/ultimate-post-slick.css" />
    <link rel="stylesheet" href="/wp-legacy/qubely-style.min.css" />
    <link rel="stylesheet" href="/wp-legacy/addtoany.min.css" />
  </Fragment>

  {
    homePage ? (
      <>
        <article class="legacy-home-content" set:html={legacyHomeHtml} />
        {homeShareHtml && <div class="legacy-home-share" set:html={homeShareHtml} />}
      </>
    ) : (
      <section class="listing-hero">
        <p class="eyebrow">Missing Source</p>
        <h1>Homepage source page was not found in migrated content.</h1>
      </section>
    )
  }
</BaseLayout>
