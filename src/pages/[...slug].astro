      channel: 'share',
      label: 'Share',
      icon: '<svg viewBox="0 0 24 24" focusable="false"><path d="M17 15.1c-1 0-1.9.4-2.5 1.1l-5-2.9a3.5 3.5 0 0 0 0-2.5l5-2.9A3.2 3.2 0 1 0 13.6 6c0 .2 0 .3.1.5l-5 2.9a3.2 3.2 0 1 0 0 5.2l5 2.9c0 .2-.1.3-.1.5a3.4 3.4 0 1 0 3.4-2.9Z"/></svg>'
    }
  ];

  const socialLinks = channels
    .map(
      (item) => {
        const href = item.channel === 'share'
          ? `https://www.addtoany.com/share#url=${linkUrl}&title=${linkName}`
          : `https://www.addtoany.com/add_to/${item.channel}?linkurl=${linkUrl}&linkname=${linkName}`;
        return `<a class="a2a_button_${item.channel} legacy-share-link legacy-share-link--${item.channel}" href="${href}" title="${item.label}" aria-label="${item.label}" rel="nofollow noopener" target="_blank"><span class="legacy-share-link__icon" aria-hidden="true">${item.icon}</span></a>`;
      }
    )
    .join('');

  return `<div class="addtoany_share_save_container addtoany_content addtoany_content_bottom"><div class="a2a_kit a2a_kit_size_32 addtoany_list legacy-share-list" data-a2a-url="${shareUrl}" data-a2a-title="${escapedTitle}">${socialLinks}</div></div>`;
}

function applyLegacyPageVariant(body: string, currentPath: string): string {
  if (normalizeRoutePath(currentPath) !== '/hichee-blog-for-hosts/') {
    return body;
  }

  return body.replace(
    /<div\s+class="ultp-post-grid-block[^"]*\bultp-block-4e76f3\b[^"]*"[^>]*>[\s\S]*?<div\s+class="pagination-block-html"[^>]*>\s*<\/div>\s*<\/div>/i,
    getHostsSoftwareBlockHtml()
  );
}

function normalizeLegacySimilarBlockHtml(blockHtml: string, currentPath: string): string {
  if (!blockHtml) return '';

  let html = blockHtml;
  html = html.replace(/\sloading=(["'])lazy\1/gi, '');

  html = html.replace(
    /<source\b([^>]*?)\sdata-lazy-srcset=(["'])([^"']+)\2([^>]*)>/gi,
    (_full, before, _quote, lazySrcset, after) => {
      let tag = `<source${before}${after}>`;
      if (/\ssrcset=(["']).*?\1/i.test(tag)) {
        tag = tag.replace(/\ssrcset=(["']).*?\1/i, ` srcset="${lazySrcset}"`);
      } else {
        tag = tag.replace('<source', `<source srcset="${lazySrcset}"`);
      }
      return tag;
    }
  );

  html = html.replace(
    /<img\b([^>]*?)\sdata-lazy-src=(["'])([^"']+)\2([^>]*)>/gi,
    (_full, before, _quote, lazySrc, after) => {
      let tag = `<img${before}${after}>`;
      if (/\ssrc=(["']).*?\1/i.test(tag)) {
        tag = tag.replace(/\ssrc=(["']).*?\1/i, ` src="${lazySrc}"`);
      } else {
        tag = tag.replace('<img', `<img src="${lazySrc}"`);
      }
      return tag;
    }
  );

  return normalizeContentHtml(html, currentPath, false);
}

function buildTiffanyAuthorBoxHtml(): string {
  return `<div class="saboxplugin-wrap" itemtype="http://schema.org/Person" itemscope="" itemprop="author"><div class="saboxplugin-tab"><div class="saboxplugin-gravatar"><img decoding="async" src="/wp-content/uploads/2023/07/Screenshot-2023-07-17-at-09.20.40.png" width="100" height="100" alt="Tiffany Mae" itemprop="image"></div><div class="saboxplugin-authorname"><a href="/author/tiffany/" class="vcard author" rel="author"><span class="fn">Tiffany Martin</span></a></div><div class="saboxplugin-desc"><div itemprop="description"><p>Tiffany Martin, a 33-year-old travel content contributor based in Manila, Philippines, brings the world’s beauty to your screen through her writing, narrating the best places in the globe with a charm that resonates.</p><p>Aside from being a travel writer and an all-around digital nomad, she’s also a wifey, a mom to two girls, and a licensed educator. During her downtime, she loves traveling, cooking, and playing with her energetic Dachshund and cuddly Golden Malinois.</p></div></div><div class="clearfix"></div></div></div>`;
}

function buildAlanAuthorBoxHtml(): string {
  return `<div class="saboxplugin-wrap" itemtype="http://schema.org/Person" itemscope="" itemprop="author"><div class="saboxplugin-tab"><div class="saboxplugin-gravatar"><img decoding="async" src="/wp-content/uploads/2022/07/hichee-logo-64-pix-1.jpg" width="100" height="100" alt="Alan Egan" itemprop="image"></div><div class="saboxplugin-authorname"><a href="/author/alan/" class="vcard author" rel="author"><span class="fn">Alan Egan</span></a></div><div class="saboxplugin-desc"><div itemprop="description"><p>Alan has been working in the vacation rental sector since 2004 and has written hundreds of articles for hosts and travelers.</p><p>His focus is practical travel and hosting advice that helps readers save money and book with confidence.</p></div></div><div class="clearfix"></div></div></div>`;
}

function inferAuthorName(route: string, body: string, legacyAuthorSlug: string, tiffanyRoutes: Set<string>): string {
  const inlineFnMatch = body.match(/<span[^>]*class=(["'])fn\1[^>]*>([^<]+)<\/span>/i);
  const inlineName = inlineFnMatch?.[2]?.trim();
  if (inlineName) return inlineName;
  if (legacyAuthorSlug === 'tiffany') return 'Tiffany Martin';
  if (legacyAuthorSlug === 'our-discount-desk') return 'Our Discount Desk';
  if (legacyAuthorSlug === 'our-travel-reporter') return 'Our Travel Reporter';
  if (legacyAuthorSlug === 'alan') return 'Alan Egan';
  if (tiffanyRoutes.has(route)) return 'Tiffany Martin';
  return 'Alan Egan';
}

function toAuthorSlug(name: string): string {
  const normalized = String(name || '').trim().toLowerCase();
  if (normalized === 'alan egan') return 'alan';
  if (normalized === 'tiffany martin' || normalized === 'tiffany mae') return 'tiffany';
  if (normalized === 'our discount desk') return 'our-discount-desk';
  if (normalized === 'our travel reporter') return 'our-travel-reporter';
  return '';
}

function inferAuthorSlugFromPath(
  route: string,
  mapping: Record<string, string[]>
): string {
  const normalizedRoute = normalizeRoutePath(route);
  for (const [slug, paths] of Object.entries(mapping)) {
    if (!Array.isArray(paths)) continue;
    for (const value of paths) {
      if (normalizeRoutePath(value) === normalizedRoute) return slug;
    }
  }
  return '';
}

function normalizeRoutePath(inputPath: string): string {
  const raw = String(inputPath || '').replace(/%ef%bf%bc/gi, '').replace(/\uFFFC/g, '');
  if (!raw) return '/';
  const withStart = raw.startsWith('/') ? raw : `/${raw}`;
  const normalized = withStart.endsWith('/') ? withStart : `${withStart}/`;
  return canonicalizeAliasPath(normalized);
}

function pickRelatedPosts<
  T extends { id: string; data: { path: string; title: string; date: Date; categories: string[]; tags: string[] } }
>({
  allPosts,
  currentPostId,
  currentPath,
  currentTitle,
  currentDate,
  categories,
  tags,
  legacyRelatedByRoute
}: {
  allPosts: T[];
  currentPostId: string;
  currentPath: string;
  currentTitle: string;
  currentDate: Date;
  categories: string[];
  tags: string[];
  legacyRelatedByRoute: Record<string, string[]>;
}): { post: T; href: string }[] {
  const byPath = new Map(allPosts.map((post) => [normalizeRoutePath(post.data.path), post] as const));
  const aliasPathToCanonicalPath = new Map<string, string>([
    ['/where-am-i-24-2/', '/where-am-i-24/'],
    [
      '/best-cheap-flights-websites-nobody-is-talking-about-how-to-find-cheap-flights-2022\uFFFC/',
      '/best-cheap-flights-websites-nobody-is-talking-about-how-to-find-cheap-flights-2022/'
    ],
    [
      '/how-to-get-longer-bookings-and-monthly-bookings-on-airbnb-and-vrbo\uFFFC/',
      '/how-to-get-longer-bookings-and-monthly-bookings-on-airbnb-and-vrbo/'
    ],
    [
      '/youll-lose-thousands-hosting-on-airbnb-if-you-do-this\uFFFC/',
      '/youll-lose-thousands-hosting-on-airbnb-if-you-do-this/'
    ]
  ]);
  const route = normalizeRoutePath(currentPath);
  const legacyPaths = legacyRelatedByRoute[route] ?? [];
  const targetCount = legacyPaths.length > 0 ? Math.min(6, legacyPaths.length) : 3;

  const out: { post: T; href: string }[] = [];
  const seen = new Set<string>();

  for (const relatedPath of legacyPaths) {
    const normalizedRelatedPath = normalizeRoutePath(relatedPath);
    const canonicalRelatedPath = aliasPathToCanonicalPath.get(normalizedRelatedPath) ?? normalizedRelatedPath;
    const mapped = byPath.get(canonicalRelatedPath);
    if (!mapped) continue;
    if (mapped.id === currentPostId || seen.has(mapped.id)) continue;
    out.push({ post: mapped, href: normalizedRelatedPath });
    seen.add(mapped.id);
    if (out.length >= targetCount) return out;
  }

  if (legacyPaths.length > 0) return out;

  const currentCategorySet = new Set(categories);
  const currentTagSet = new Set(tags);
  const currentTokenSet = tokenizeRelatedText(`${currentTitle} ${currentPath}`);
  const currentTime = currentDate?.getTime?.() ?? 0;

  const scored = allPosts
    .filter((post) => post.id !== currentPostId && !seen.has(post.id))
    .map((post) => {
      const categoryOverlap = countSetOverlap(post.data.categories, currentCategorySet);
      const tagOverlap = countSetOverlap(post.data.tags, currentTagSet);
      const tokenSet = tokenizeRelatedText(`${post.data.title} ${post.data.path}`);
      const lexicalOverlap = countSetOverlap(tokenSet, currentTokenSet);
      const lexicalUnion = tokenSet.size + currentTokenSet.size - lexicalOverlap;
      const lexicalScore = lexicalUnion > 0 ? lexicalOverlap / lexicalUnion : 0;
      const dateTime = post.data.date?.getTime?.() ?? 0;
      const dayDistance = currentTime && dateTime ? Math.abs(currentTime - dateTime) / 86400000 : 3650;
      const recencyScore = Math.max(0, 1 - dayDistance / 3650);

      return {
        post,
        dateTime,
        score: categoryOverlap * 8 + tagOverlap * 6 + lexicalScore * 14 + recencyScore * 1.5
      };
    })
    .sort((left, right) => right.score - left.score || right.dateTime - left.dateTime);

  for (const candidate of scored) {
    out.push({ post: candidate.post, href: candidate.post.data.path });
    if (out.length >= targetCount) break;
  }

  return out;
}

function tokenizeRelatedText(value: string): Set<string> {
  const normalized = String(value || '')
    .toLowerCase()
    .replace(/%ef%bf%bc/gi, ' ')
    .replace(/\uFFFC/g, ' ')
    .replace(/&amp;/gi, ' and ')
    .replace(/[^a-z0-9]+/g, ' ')
    .trim();

  if (!normalized) return new Set();

  return new Set(
    normalized
      .split(/\s+/)
      .filter((token) => token.length > 2)
      .filter((token) => !RELATED_STOP_WORDS.has(token))
  );
}

function countSetOverlap(values: Iterable<string>, comparisonSet: Set<string>): number {
  let total = 0;
  for (const value of values) {
    if (comparisonSet.has(value)) total += 1;
  }
  return total;
}
---

<BaseLayout
  title={pageTitle}
  description={entry.data.description}
  canonical={canonical}
  bodyClass={pageBodyClass}
>
  {isLegacyPage && (
    <Fragment slot="head">
      <link rel="stylesheet" href="/wp-legacy/wp-block-library.min.css" />
      <link rel="stylesheet" href="/wp-legacy/wp-block-theme.min.css" />
      <link rel="stylesheet" href="/wp-legacy/getwid-blocks.style.css" />
      <link rel="stylesheet" href="/wp-legacy/kadence-global.min.css" />
      <link rel="stylesheet" href="/wp-legacy/kadence-header.min.css" />
      <link rel="stylesheet" href="/wp-legacy/kadence-footer.min.css" />
      <link rel="stylesheet" href="/wp-legacy/ultimate-post-style.min.css" />
      <link rel="stylesheet" href="/wp-legacy/ultimate-post-slick.css" />
      <link rel="stylesheet" href="/wp-legacy/qubely-style.min.css" />
      <link rel="stylesheet" href="/wp-legacy/addtoany.min.css" />
      {isHostsLandingPage && <link rel="stylesheet" href="/wp-legacy/hichee-hosts-inline.css" />}
    </Fragment>
  )}

  {isPost && (
    <Fragment slot="head">
      <link rel="stylesheet" href="/wp-legacy/addtoany.min.css" />
    </Fragment>
  )}

  {isLegacyPage ? (
    <article class:list={['legacy-home-content', 'legacy-page-content', isHostsLandingPage && 'legacy-page-content--hosts']}>
      <Fragment set:html={legacyPageHtml} />
      {shareHtml && <Fragment set:html={shareHtml} />}
    </article>
  ) : (
    <article class="article-shell article-shell--post">
      <header class="article-header">
        {isPost && categoryChips.length > 0 && (
          <div class="taxonomy">
            {categoryChips.map((category) => (
              <a class="badge" href={`/category/${category.slug}/`}>{category.label}</a>
            ))}
          </div>
        )}

        <h1>{entry.data.title}</h1>
        {isPost && (
          <p class="meta">
            By{' '}
            {authorSlug ? (
              <a href={`/author/${authorSlug}/`}>{authorName}</a>
            ) : (
              <span>{authorName}</span>
            )}
          </p>
        )}
      </header>

      {shouldRenderFeaturedImage && (
        <img
          src={featuredImage}
          alt={entry.data.featuredImageAlt ?? entry.data.title}
          loading="lazy"
          decoding="async"
          class="article-hero-image"
        />
      )}

      <section class="article-content">
        {shouldUseRewrittenPostHtml ? <Fragment set:html={rewrittenPostHtml} /> : <Content />}
        {legacySimilarBlockHtml && <Fragment set:html={legacySimilarBlockHtml} />}
        {fallbackAuthorBoxHtml && <Fragment set:html={fallbackAuthorBoxHtml} />}
      </section>

      {shareHtml && <Fragment set:html={shareHtml} />}

      {shouldRenderRelatedPosts && (
        <section class="similar-posts">
          <h2>Similar Posts</h2>
          <div class="similar-posts__grid">
            {relatedPosts.map((post) => (
              <article class="similar-post">
                <a class="similar-post__image" href={post.href}>
                  {post.post.data.featuredImage ? (
                    <img
                      src={normalizeWpUploadUrl(post.post.data.featuredImage)}
                      alt={post.post.data.featuredImageAlt ?? post.post.data.title}
                      loading="lazy"
                      decoding="async"
                    />
                  ) : (
                    <span class="similar-post__placeholder">{post.post.data.title.slice(0, 1).toUpperCase()}</span>
                  )}
                </a>
                <h3>
                  <a href={post.href}>{post.post.data.title}</a>
                </h3>
              </article>
            ))}
          </div>
        </section>
      )}

      {isPost && (newerPost || olderPost) && (
        <nav class="article-nav" aria-label="Post navigation">
          {newerPost ? (
            <a class="article-nav__item" href={newerPost.data.path}>
              <small>Previous</small>
              <span>{newerPost.data.title}</span>
            </a>
          ) : (
            <span></span>
          )}
          {olderPost && (
            <a class="article-nav__item article-nav__item--right" href={olderPost.data.path}>
              <small>Next</small>
              <span>{olderPost.data.title}</span>
            </a>
          )}
        </nav>
      )}
    </article>
  )}
</BaseLayout>
