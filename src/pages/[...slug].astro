agers use for their vacation rental" src="https://blog.hichee.com/wp-content/uploads/2022/11/laptop-593673_1280-870x570.jpg" /></a></div><div class="ultp-block-content"><h3 class="ultp-block-title"><a href="https://blog.hichee.com/top-9-website-builders-property-managers-use-for-their-vacation-rental/">Top 9 website builders property managers use for their vacation rental</a></h3></div></div></div><div class="ultp-block-item post-id-4793"><div class="ultp-block-content-wrap"><div class="ultp-block-image ultp-block-image-opacity"><a href="https://blog.hichee.com/top-7-best-vacation-rental-channel-managers-in-2022/"><img decoding="async" alt="Top 7 Best Vacation Rental Channel Managers in 2022" src="https://blog.hichee.com/wp-content/uploads/2022/11/Top-7-Best-Vacation-Rental-Channel-Managers-in-2022-870x570.jpg" /></a></div><div class="ultp-block-content"><h3 class="ultp-block-title"><a href="https://blog.hichee.com/top-7-best-vacation-rental-channel-managers-in-2022/">Top 7 Best Vacation Rental Channel Managers in 2022</a></h3></div></div></div></div></div><div class="pagination-block-html" aria-hidden="true" style="display: none;"></div></div>`;
}

function rewriteLegacyPageHtml(body: string, currentPath: string): string {
  let html = applyLegacyPageVariant(body, currentPath);
  html = normalizeContentHtml(html, currentPath, true);
  return html;
}

function rewritePostHtml(body: string, currentPath: string): string {
  const extractedPostHtml = extractPostHtmlFromMdx(body);
  const htmlToNormalize = extractedPostHtml ?? body;
  if (!htmlToNormalize) return '';
  return normalizeContentHtml(htmlToNormalize, currentPath, false);
}

function extractPostHtmlFromMdx(body: string): string | null {
  const marker = 'export const postHtml = ';
  const markerIndex = body.indexOf(marker);
  if (markerIndex === -1) return null;

  const afterMarker = body.slice(markerIndex + marker.length).trimStart();
  if (!afterMarker.startsWith('"')) return null;

  let index = 1;
  let escaped = false;

  while (index < afterMarker.length) {
    const char = afterMarker[index];
    if (escaped) {
      escaped = false;
      index += 1;
      continue;
    }
    if (char === '\\') {
      escaped = true;
      index += 1;
      continue;
    }
    if (char === '"') break;
    index += 1;
  }

  if (index >= afterMarker.length) return null;

  const literal = afterMarker.slice(0, index + 1);
  try {
    return JSON.parse(literal) as string;
  } catch {
    return null;
  }
}

function normalizeContentHtml(body: string, currentPath: string, stripLazyLoading: boolean): string {
  let html = rewriteInternalLinks(body, currentPath);
  html = repairInPageHashLinks(html);
  html = rewriteWpUploadsInHtml(html);

  // Remove WordPress author-box admin controls that should never be public.
  html = html.replace(
    /<div[^>]*class=(["'])[^"']*\bsab-edit-settings\b[^"']*\1[^>]*>[\s\S]*?<\/div>/gi,
    ''
  );

  // Remove dead social placeholders left behind when legacy share widgets are stripped.
  html = html.replace(
    /<p>\s*<a[^>]*href=(["'])#(?:facebook|twitter|pinterest|whatsapp|email|linkedin|reddit|messenger|copy_link|telegram|line|sms)\1[^>]*>\s*<\/a>\s*<\/p>/gi,
    ''
  );

  if (stripLazyLoading) {
    // Improve visual parity by avoiding deferred image paint for static migrated blocks.
    html = html.replace(/\sloading=(["'])lazy\1/gi, '');
  }

  return html;
}

function repairInPageHashLinks(body: string): string {
  const idMatches = [...body.matchAll(/\sid=(["'])([^"']+)\1/gi)];
  if (idMatches.length === 0) return body;

  const ids = new Set<string>();
  const canonicalToId = new Map<string, string>();

  for (const [, , rawId] of idMatches) {
    const id = String(rawId || '');
    if (!id) continue;
    ids.add(id);

    const canonical = canonicalizeHashToken(id);
    if (canonical && !canonicalToId.has(canonical)) {
      canonicalToId.set(canonical, id);
    }

    if (id.toLowerCase().startsWith('h-')) {
      const withoutPrefix = canonicalizeHashToken(id.slice(2));
      if (withoutPrefix && !canonicalToId.has(withoutPrefix)) {
        canonicalToId.set(withoutPrefix, id);
      }
    }
  }

  return body.replace(/\shref=(["'])#([^"']+)\1/gi, (full, quote, targetRaw) => {
    const target = String(targetRaw || '');
    if (!target) return full;
    if (ids.has(target)) return full;

    const decoded = decodeUriComponentSafely(target);
    const variants = new Set<string>([
      target,
      decoded,
      target.replace(/\s+/g, '-'),
      decoded.replace(/\s+/g, '-'),
      target.replace(/_/g, '-'),
      decoded.replace(/_/g, '-'),
      target.replace(/-/g, '_'),
      decoded.replace(/-/g, '_')
    ]);

    const slugTarget = slugifyHashToken(target);
    const slugDecoded = slugifyHashToken(decoded);
    if (slugTarget) {
      variants.add(slugTarget);
      variants.add(`h-${slugTarget}`);
      variants.add(slugTarget.replace(/-/g, '_'));
    }
    if (slugDecoded) {
      variants.add(slugDecoded);
      variants.add(`h-${slugDecoded}`);
      variants.add(slugDecoded.replace(/-/g, '_'));
    }

    for (const variant of variants) {
      if (ids.has(variant)) return ` href=${quote}#${variant}${quote}`;
    }

    const canonicalCandidates = [canonicalizeHashToken(target), canonicalizeHashToken(decoded)].filter(Boolean);
    for (const canonical of canonicalCandidates) {
      const mapped = canonicalToId.get(canonical);
      if (mapped) return ` href=${quote}#${mapped}${quote}`;
    }

    // Keep dead legacy TOC links from jumping to a bad location.
    return ` href=${quote}#${quote}`;
  });
}

function decodeUriComponentSafely(value: string): string {
  const raw = String(value || '').replace(/\+/g, ' ').trim();
  if (!raw) return '';
  try {
    return decodeURIComponent(raw);
  } catch {
    return raw;
  }
}

function slugifyHashToken(value: string): string {
  const decoded = decodeUriComponentSafely(value);
  return decoded
    .replace(/&amp;/gi, 'and')
    .replace(/[^A-Za-z0-9\s_-]/g, ' ')
    .replace(/[_\s]+/g, '-')
    .replace(/-+/g, '-')
    .replace(/^-+|-+$/g, '');
}

function canonicalizeHashToken(value: string): string {
  const decoded = decodeUriComponentSafely(value);
  return decoded
    .replace(/&amp;/gi, 'and')
    .replace(/[_-]+/g, ' ')
    .replace(/[^A-Za-z0-9\s]/g, ' ')
    .replace(/\s+/g, ' ')
    .trim()
    .toLowerCase();
}

function rewriteInternalLinks(body: string, currentPath: string): string {
  return body.replace(/\shref=(["'])([^"']+)\1/gi, (full, quote, pathValue) => {
    const rewritten = rewriteInternalHref(pathValue, currentPath);
    if (rewritten === null) return full;
    return ` href=${quote}${rewritten}${quote}`;
  });
}

function rewriteInternalHref(pathValue: string, currentPath: string): string | null {
  const raw = String(pathValue || '')
    .replace(/&#038;/gi, '&')
    .replace(/&amp;/gi, '&')
    .trim();

  if (!raw || raw === '/') return '/';
  if (raw.startsWith('#')) return raw;
  if (raw.startsWith('mailto:') || raw.startsWith('tel:') || raw.startsWith('javascript:')) return null;
  if (raw.startsWith('//')) return null;

  if (/^https?:\/\//i.test(raw)) {
    let parsedExternal: URL;
    try {
      parsedExternal = new URL(raw);
    } catch {
      return null;
    }

    if (parsedExternal.hostname !== 'blog.hichee.com') return null;
    return rewriteInternalPathValue(
      `${parsedExternal.pathname}${parsedExternal.search}${parsedExternal.hash}`,
      currentPath
    );
  }

  if (!raw.startsWith('/')) return null;
  return rewriteInternalPathValue(raw, currentPath);
}

function rewriteInternalPathValue(pathValue: string, currentPath: string): string | null {
  const raw = String(pathValue || '').replace(/%ef%bf%bc/gi, '').replace(/\uFFFC/g, '');
  const normalizedCurrentPath = normalizeRoutePath(currentPath);

  if (!raw || raw === '/') return '/';
  if (raw.startsWith('/#')) return raw.slice(1);

  if (raw.startsWith('/wp-json/wp/v2/pages')) {
    const pageMatch = raw.match(/\/wp-json\/wp\/v2\/pages\/page\/(\d+)\/?/i);
    if (pageMatch) return `${normalizedCurrentPath}page/${pageMatch[1]}/`;
    const queryPageMatch = raw.match(/[?&]page=(\d+)/i);
    if (queryPageMatch && queryPageMatch[1] !== '1') return `${normalizedCurrentPath}page/${queryPageMatch[1]}/`;
    return normalizedCurrentPath;
  }

  let parsed: URL;
  try {
    parsed = new URL(raw, 'https://blog.hichee.com');
  } catch {
    return null;
  }

  const pathname = parsed.pathname.replace(/%ef%bf%bc/gi, '').replace(/\uFFFC/g, '');
  if (!pathname || pathname === '/') {
    if (/[?&]amp=1/i.test(parsed.search)) return parsed.hash || '#';
    if (parsed.search || parsed.hash) return `/${parsed.search}${parsed.hash}`;
    return '/';
  }

  if (pathname.startsWith('/wp-content/') || pathname.startsWith('/wp-admin/') || pathname.startsWith('/wp-json/')) {
    return null;
  }
  if (/[?&]amp=1/i.test(parsed.search)) return parsed.hash || '#';

  const normalizedPath = normalizeRoutePath(pathname);
  if (normalizedPath === normalizedCurrentPath && !parsed.search) {
    return parsed.hash || '#';
  }

  return `${normalizedPath}${parsed.search}${parsed.hash}`;
}

