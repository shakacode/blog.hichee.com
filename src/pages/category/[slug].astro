---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import taxonomy from '../../data/taxonomy.json';

export async function getStaticPaths() {
  const posts = (await getCollection('posts')).filter(
    (entry) => !entry.data.draft && entry.data.status === 'publish'
  );
  const categories = new Set(posts.flatMap((post) => post.data.categories));

  return [...categories].map((slug) => ({ params: { slug } }));
}

const slug = Astro.params.slug as string;

const posts = (await getCollection('posts'))
  .filter((entry) => !entry.data.draft && entry.data.status === 'publish')
  .filter((entry) => entry.data.categories.includes(slug))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const categoryLabel = taxonomy.categories[slug as keyof typeof taxonomy.categories] ?? slug;
---

<BaseLayout
  title={`Category: ${categoryLabel}`}
  description={`Posts in ${categoryLabel}`}
  canonical={`/category/${slug}/`}
>
  <section class="listing-hero">
    <p class="eyebrow">Category</p>
    <h1>{categoryLabel}</h1>
    <p>{posts.length} posts</p>
  </section>

  <div class="post-grid">
    {posts.map((post) => <PostCard post={post} />)}
  </div>
</BaseLayout>
