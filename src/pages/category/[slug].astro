---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = (await getCollection('posts')).filter(
    (entry) => !entry.data.draft && entry.data.status === 'publish'
  );
  const categories = new Set(posts.flatMap((post) => post.data.categories));

  return [...categories].map((slug) => ({ params: { slug } }));
}

const slug = Astro.params.slug as string;

const posts = (await getCollection('posts'))
  .filter((entry) => !entry.data.draft && entry.data.status === 'publish')
  .filter((entry) => entry.data.categories.includes(slug))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title={`Category: ${slug}`} description={`Posts in ${slug}`} canonical={`/category/${slug}/`}>
  <h1>Category: {slug}</h1>
  <div class="post-list">
    {
      posts.map((post) => (
        <article class="post-card">
          <h2><a href={post.data.path}>{post.data.title}</a></h2>
          <p class="meta">{post.data.date.toISOString().slice(0, 10)}</p>
        </article>
      ))
    }
  </div>
</BaseLayout>
