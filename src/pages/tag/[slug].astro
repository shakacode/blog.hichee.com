---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';

export async function getStaticPaths() {
  const posts = (await getCollection('posts')).filter(
    (entry) => !entry.data.draft && entry.data.status === 'publish'
  );
  const tags = new Set(posts.flatMap((post) => post.data.tags));

  return [...tags].map((slug) => ({ params: { slug } }));
}

const slug = Astro.params.slug as string;

const posts = (await getCollection('posts'))
  .filter((entry) => !entry.data.draft && entry.data.status === 'publish')
  .filter((entry) => entry.data.tags.includes(slug))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title={`Tag: ${slug}`} description={`Posts tagged ${slug}`} canonical={`/tag/${slug}/`}>
  <section class="listing-hero">
    <p class="eyebrow">Tag</p>
    <h1>#{slug}</h1>
    <p>{posts.length} posts</p>
  </section>

  <div class="post-grid">
    {posts.map((post) => <PostCard post={post} />)}
  </div>
</BaseLayout>
